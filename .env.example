# ==========================================
# 三星事业部管理平台 - 环境变量配置
# 复制此文件为 .env 并修改对应值
# ==========================================

# 服务器配置
SAMSUNG_HOST=0.0.0.0
SAMSUNG_PORT=9527
SAMSUNG_DEBUG=false

# JWT 认证（生产环境务必修改此密钥！）
SAMSUNG_SECRET_KEY=change-this-to-a-random-string-in-production
SAMSUNG_TOKEN_EXPIRE_HOURS=72

# 数据库
SAMSUNG_DB_JOURNAL_MODE=delete
SAMSUNG_BACKUP_DIR=%USERPROFILE%\Desktop\samsung_ops_backup
SAMSUNG_BACKUP_RETENTION_DAYS=7

# 钉钉集成
SAMSUNG_DINGTALK_ADMIN_USER_ID=16381712592737652
SAMSUNG_DINGTALK_ROBOT_WEBHOOK=
SAMSUNG_DINGTALK_ACCESS_TOKEN=

# eBoss 目录
SAMSUNG_EBOSS_DIR=C:\eBoss\Local

# 定时任务
SAMSUNG_SCHEDULER_ENABLED=true
SAMSUNG_INVENTORY_ALERT_DAYS=mon,thu
SAMSUNG_INVENTORY_ALERT_HOUR=9
SAMSUNG_INVENTORY_ALERT_MINUTE=30
SAMSUNG_PRICE_CHECK_HOUR=10
SAMSUNG_BACKUP_HOUR=3
SAMSUNG_EBOSS_SCAN_INTERVAL=60

# 日志
SAMSUNG_LOG_LEVEL=INFO

# 管理员默认配置（仅首次初始化时使用）
SAMSUNG_ADMIN_USERNAME=admin
SAMSUNG_ADMIN_PASSWORD=admin123
SAMSUNG_STORE_PASSWORD=store123

# AI 智能助手配置（可选，留空则 AI 助手不可用）
SAMSUNG_AI_API_KEY=your-api-key-here
SAMSUNG_AI_BASE_URL=https://api.deepseek.com/v1
SAMSUNG_AI_MODEL=deepseek-chat
SAMSUNG_AI_MAX_TOKENS=2000
SAMSUNG_AI_TEMPERATURE=0.3
SAMSUNG_AI_MAX_HISTORY=20
SAMSUNG_AI_RATE_LIMIT=30

# 安全增强配置
SAMSUNG_SESSION_TIMEOUT=3600  # 会话超时时间（秒）
SAMSUNG_MAX_LOGIN_ATTEMPTS=5  # 最大登录尝试次数
SAMSUNG_LOGIN_LOCKOUT_TIME=300  # 登录锁定时间（秒）
SAMSUNG_PASSWORD_MIN_LENGTH=8  # 密码最小长度
SAMSUNG_ENABLE_2FA=false  # 是否启用双因素认证（预留）
