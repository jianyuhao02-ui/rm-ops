dotenv
# ==========================================
# 零售管理平台 - 环境变量配置
# 复制此文件为 .env 并修改对应值
# ==========================================

# 服务器配置
RM_HOST=0.0.0.0
RM_PORT=9527
RM_DEBUG=false

# JWT 认证（生产环境务必修改此密钥！）
RM_SECRET_KEY=change-this-to-a-random-string-in-production
RM_TOKEN_EXPIRE_HOURS=72

# 数据库
RM_DB_JOURNAL_MODE=delete
RM_BACKUP_DIR=%USERPROFILE%\Desktop\rm_ops_backup
RM_BACKUP_RETENTION_DAYS=7

# 钉钉集成
RM_DINGTALK_ADMIN_USER_ID=16381712592737652
RM_DINGTALK_ROBOT_WEBHOOK=
RM_DINGTALK_ACCESS_TOKEN=

# eBoss 目录
RM_EBOSS_DIR=C:\eBoss\Local

# 定时任务
RM_SCHEDULER_ENABLED=true
RM_INVENTORY_ALERT_DAYS=mon,thu
RM_INVENTORY_ALERT_HOUR=9
RM_INVENTORY_ALERT_MINUTE=30
RM_PRICE_CHECK_HOUR=10
RM_BACKUP_HOUR=3
RM_EBOSS_SCAN_INTERVAL=60

# 日志
RM_LOG_LEVEL=INFO

# 管理员默认配置（仅首次初始化时使用）
RM_ADMIN_USERNAME=admin
RM_ADMIN_PASSWORD=admin123
RM_STORE_PASSWORD=store123

# AI 智能助手配置（可选，留空则 AI 助手不可用）
RM_AI_API_KEY=your-api-key-here
RM_AI_BASE_URL=https://api.deepseek.com/v1
RM_AI_MODEL=deepseek-chat
RM_AI_MAX_TOKENS=2000
RM_AI_TEMPERATURE=0.3
RM_AI_MAX_HISTORY=20
RM_AI_RATE_LIMIT=30

# 安全增强配置
RM_SESSION_TIMEOUT=3600  # 会话超时时间（秒）
RM_MAX_LOGIN_ATTEMPTS=5  # 最大登录尝试次数
RM_LOGIN_LOCKOUT_TIME=300  # 登录锁定时间（秒）
RM_PASSWORD_MIN_LENGTH=8  # 密码最小长度
RM_ENABLE_2FA=false  # 是否启用双因素认证（预留）
